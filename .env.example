# ============================================================
# .env.example — backend-notification-service
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitear el .env real al repositorio.
# ============================================================

# ─── Django ──────────────────────────────────────────────────
# Clave secreta de Django. Generar con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
NOTIFICATION_SERVICE_SECRET_KEY=cambia-esto-por-una-clave-secreta-real

# true en desarrollo, false en produccion
DJANGO_DEBUG=false

# Hosts permitidos separados por coma (ej: localhost,127.0.0.1,notification-service)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos PostgreSQL ─────────────────────────────────
POSTGRES_DB=notifications_db
POSTGRES_USER=notif_user
POSTGRES_PASSWORD=notif_pass
# En Docker: nombre del servicio del compose. En local: localhost
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── RabbitMQ ────────────────────────────────────────────────
# En Docker: nombre del servicio del compose. En local: localhost
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Exchange fanout donde el ticket-service publica eventos
RABBITMQ_EXCHANGE_NAME=tickets_exchange

# Cola exclusiva de este servicio
RABBITMQ_QUEUE_NOTIFICATION=notification_queue

# Configuracion de reconexion (US-E5-01)
RABBITMQ_INITIAL_RETRY_DELAY=1
RABBITMQ_MAX_RETRY_DELAY=60
RABBITMQ_RETRY_BACKOFF_FACTOR=2
RABBITMQ_MAX_RETRIES=0

# ─── JWT ─────────────────────────────────────────────────────
# Clave de firma JWT. Debe coincidir con la del ticket-service.
JWT_SECRET_KEY=cambia-esto-por-la-misma-clave-jwt-del-ticket-service

# ─── CORS ────────────────────────────────────────────────────
# Origenes permitidos separados por coma
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Origenes confiables para CSRF
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ─── Gunicorn ────────────────────────────────────────────────
# Numero de workers. Regla general: (2 * CPUs) + 1
GUNICORN_WORKERS=2
# Timeout en segundos. Mínimo 120 para soportar SSE (Server-Sent Events)
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:8001
# gevent requerido para SSE de larga duración (sync workers matan el proceso)
GUNICORN_WORKER_CLASS=gevent